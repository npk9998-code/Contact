generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════
// المؤسسة (الشركة)
// ═══════════════════════════════════════
model Organization {
  id        String   @id @default(cuid())
  name      String
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees Employee[]
  lines     Line[]
  clients   Client[]
}

// ═══════════════════════════════════════
// الموظفون والصلاحيات
// ═══════════════════════════════════════
model Employee {
  id           String    @id @default(cuid())
  orgId        String
  name         String
  phone        String    @unique   // رقم الجوال للـ OTP
  passwordHash String
  role         Role      @default(AGENT)
  isActive     Boolean   @default(true)
  avatar       String?
  createdAt    DateTime  @default(now())
  lastLogin    DateTime?

  org           Organization   @relation(fields: [orgId], references: [id])
  permissions   Permission[]
  sessions      Session[]
  assignedLines EmployeeLine[]
  otpCodes      OtpCode[]

  @@index([orgId])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  AGENT
}

model Permission {
  id         String  @id @default(cuid())
  employeeId String
  resource   String   // "calls", "whatsapp", "clients", "reports", "settings", "lines"
  canRead    Boolean @default(true)
  canWrite   Boolean @default(false)
  canDelete  Boolean @default(false)

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, resource])
}

// ═══════════════════════════════════════
// الجلسات والمصادقة (OTP + JWT)
// ═══════════════════════════════════════
model Session {
  id         String   @id @default(cuid())
  employeeId String
  token      String   @unique
  deviceInfo String?
  ip         String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model OtpCode {
  id         String   @id @default(cuid())
  employeeId String
  code       String
  expiresAt  DateTime
  used       Boolean  @default(false)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

// ═══════════════════════════════════════
// الأرقام والخطوط (Multi-Account Switcher)
// ═══════════════════════════════════════
model Line {
  id            String   @id @default(cuid())
  orgId         String
  name          String              // "خط المبيعات"
  displayNumber String              // "+966920000001"
  type          LineType
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  color         String?
  description   String?

  // بيانات Twilio (مشفّرة عند الحفظ)
  twilioAccountSid  String?
  twilioAuthToken   String?
  twilioPhoneNumber String?

  // بيانات WhatsApp / Meta (مشفّرة عند الحفظ)
  wabaId          String?
  waPhoneNumberId String?
  waAccessToken   String?
  waWebhookSecret String?

  // إعدادات IVR (مرحلة لاحقة)
  ivrEnabled       Boolean @default(false)
  ivrFlowJson      Json?
  greetingText     String?
  afterHoursMsg    String?
  workHoursStart   String? @default("08:00")
  workHoursEnd     String? @default("17:00")
  workDays         Int[]   @default([0, 1, 2, 3, 4])
  maxWaitSeconds   Int     @default(180)
  maxRings         Int     @default(5)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org       Organization   @relation(fields: [orgId], references: [id])
  employees EmployeeLine[]

  @@index([orgId])
}

enum LineType {
  PHONE_ONLY
  WHATSAPP_ONLY
  BOTH
}

// ربط الموظفين بالخطوط (many-to-many) — أساس Multi-Account Switcher
model EmployeeLine {
  employeeId String
  lineId     String
  canCall    Boolean  @default(true)
  canChat    Boolean  @default(true)
  isDefault  Boolean  @default(false)
  assignedAt DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  line     Line     @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@id([employeeId, lineId])
}

// ═══════════════════════════════════════
// العملاء (placeholder - يُستكمل في المرحلة القادمة)
// ═══════════════════════════════════════
model Client {
  id          String   @id @default(cuid())
  orgId       String
  name        String?
  phone       String
  email       String?
  tags        String[]
  notes       String?
  customData  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, phone])
  @@index([orgId])
}
